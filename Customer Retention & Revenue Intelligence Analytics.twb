      <aliases enabled='yes' />
      <column caption='Total Order' datatype='integer' name='[Calculation_1331727635320832]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD([InvoiceNo])' />
      </column>
      <column caption='Total Customer' datatype='integer' name='[Calculation_1331727636520961]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD([CustomerID])' />
      </column>
      <column caption='Average Order Value' datatype='real' name='[Calculation_1331727640358914]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='sum([Revenue]) / [Calculation_1331727635320832]' />
      </column>
      <column caption='Repeat Purchase ' datatype='integer' name='[Calculation_1331727644880901]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [Order_Count] &gt; 1 THEN 1 ELSE 0 END' />
      </column>
      <column caption='Avg_Customer_lifetime_value' datatype='real' name='[Calculation_1331728705560582]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='sum([Revenue])/COUNTD([CustomerID])' />
      </column>
      <column caption='Active_customer' datatype='integer' name='[Calculation_1331728707723271]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD(&#10;if [Churn_Flag] == 0 then [CustomerID] END&#10;)' />
      </column>
      <column caption='Churned_Customers' datatype='integer' name='[Calculation_1331728708411400]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD(&#10;IF [Churn_Flag] == 1 THEN [CustomerID] END&#10;)' />
      </column>
      <column caption='Champions_Customer_count' datatype='integer' name='[Calculation_1331728714727433]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD(&#10;IF [Customer_Segment] == &apos;Champions&apos;&#10; THEN [CustomerID] &#10;END&#10;)' />
      </column>
      <column caption='Retention_rate' datatype='integer' name='[Calculation_3218766288371712]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF DATETRUNC(&apos;month&apos;,[InvoiceDate]) &gt;&#10;        { FIXED [CustomerID] :&#10;            MIN(DATETRUNC(&apos;month&apos;,[InvoiceDate])) }&#10;THEN 1 ELSE 0 END' />
      </column>
      <column caption='Revenue at Risst' datatype='real' name='[Calculation_3218766290108418]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(&#10;IF [Customer_Segment] = &quot;At Risk&quot;&#10;THEN [Revenue]&#10;END&#10;)' />
      </column>
      <column caption=' Avg Orders per Customer' datatype='real' name='[Calculation_3218766292987908]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD([InvoiceNo]) / COUNTD([CustomerID])' />
      </column>
      <column caption='Cohort Month' datatype='datetime' name='[Calculation_3218766294069253]' role='dimension' type='ordinal'>
        <calculation class='tableau' formula='{ FIXED [CustomerID] : MIN(DATETRUNC(&apos;month&apos;,[InvoiceDate])) }' />
      </column>
      <column caption='Order Month' datatype='datetime' name='[Calculation_3218766294519814]' role='dimension' type='ordinal'>
        <calculation class='tableau' formula='DATETRUNC(&apos;month&apos;,[InvoiceDate])' />
      </column>
      <column caption='Cohort Index' datatype='integer' name='[Calculation_3218766294605831]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='DATEDIFF(&apos;month&apos;,[Calculation_3218766294069253],[Calculation_3218766294519814])' />
      </column>
      <column caption='Cohort Size' datatype='integer' name='[Calculation_3218766294769672]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED [Calculation_3218766294069253] : COUNTD([CustomerID]) }' />
      </column>
      <column caption='Active Customers' datatype='integer' name='[Calculation_3218766295105545]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD([CustomerID])' />
      </column>
      <column caption='cohort_Retention Rate' datatype='real' name='[Calculation_3218766295375882]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Calculation_3218766307921931]) / MIN([Calculation_3218766294769672])' />
