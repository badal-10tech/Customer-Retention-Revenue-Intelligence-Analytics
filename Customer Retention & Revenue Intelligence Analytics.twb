    <worksheet name=' Repeat Purchase Rate by Segment'>
      <layout-options>
        <title>
          <formatted-text>
            <run fontname='Tableau Semibold' fontsize='10'> Repeat Purchase Rate by Segment</run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='Ecommerce_Analytics_Final' name='federated.11u8c6i09q789q15xwu8w1mmap02' />
          </datasources>
          <datasource-dependencies datasource='federated.11u8c6i09q789q15xwu8w1mmap02'>
            <column caption='Repeat Purchase ' datatype='integer' name='[Calculation_1331727644880901]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='IF [Order_Count] &gt; 1 THEN 1 ELSE 0 END' />
